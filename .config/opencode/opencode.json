{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"provider": {
		"alfagen": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "Alfagen",
			"options": {
				"apiKey": "{env:CONTINUE_DEV_KEY}",
				"baseURL": "{env:CONTINUE_DEV_HOST}"
			},
			"models": {
				"Qwen/Qwen3-Coder-Next": {
					"name": "ALFAGEN Qwen3-Coder-Next",
					"limit": {
						"context": 256000,
						"output": 30000
					}
				},
				"zai-org/GLM-5-FP8": {
					"name": "ALFAGEN GLM-5-FP8",
					"limit": {
						"context": 204800,
						"output": 30000
					}
				},
				"Qwen/Qwen3.5-397B-A17B-FP8": {
					"name": "ALFAGEN Qwen3.5-397B-A17B-FP8",
					"limit": {
						"context": 256000,
						"output": 30000
					}
				},
				"Qwen/Qwen3-Coder-30B-A3B-Instruct": {
					"name": "ALFAGEN Qwen3-Coder-30B-A3B",
					"limit": {
						"context": 256000,
						"output": 30000
					}
				},
				"moonshotai/Kimi-K2-Thinking": {
					"name": "ALFAGEN Kimi-K2-Thinking",
					"limit": {
						"context": 256000,
						"output": 10000
					}
				},
				"openai/gpt-oss-120b": {
					"name": "ALFAGEN gpt-oss",
					"limit": {
						"context": 128000,
						"output": 10000
					}
				},
				"Qwen/Qwen3-235B-A22B-Instruct-2507-FP8": {
					"name": "ALFAGEN Qwen/Qwen3-235B-A22B-Instruct-2507-FP8",
					"temperature": true,
					"limit": {
						"context": 239717,
						"output": 10000
					}
				}
			}
		}
	},
	"disabled_providers": [
		"gemini"
	],
	"mcp": {
		"mail": {
			"type": "local",
			"command": [
				"mcp-email-server",
				"stdio"
			],
			"environment": {
				"REQUESTS_CA_BUNDLE": "/Users/rvetas/dotfiles/certs/davmail.pem",
				"SSL_CERT_FILE": "/Users/rvetas/dotfiles/certs/davmail.pem",
				"MCP_EMAIL_SERVER_ACCOUNT_NAME": "Work",
				"MCP_EMAIL_SERVER_FULL_NAME": "{env:ADNAME}",
				"MCP_EMAIL_SERVER_EMAIL_ADDRESS": "{env:ADMAIL}",
				"MCP_EMAIL_SERVER_USER_NAME": "{env:FULL_ADLOGIN}",
				"MCP_EMAIL_SERVER_PASSWORD": "{env:ADPASS}",
				"MCP_EMAIL_SERVER_IMAP_HOST": "localhost",
				"MCP_EMAIL_SERVER_IMAP_PORT": "1143",
				"MCP_EMAIL_SERVER_IMAP_SSL": "true",
				"MCP_EMAIL_SERVER_SMTP_HOST": "localhost",
				"MCP_EMAIL_SERVER_SMTP_PORT": "1145",
				"MCP_EMAIL_SERVER_SMTP_SSL": "true"
			},
			"enabled": false
		},
		"atlassian": {
			"type": "local",
			"command": [
				"uvx",
				"--python=3.12",
				"mcp-atlassian",
				"--no-jira-ssl-verify",
				"--no-confluence-ssl-verify"
			],
			"environment": {
				"JIRA_URL": "{env:JIRA_URL}",
				"JIRA_PERSONAL_TOKEN": "{env:JIRA_PERSONAL_TOKEN}",
				"CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
				"CONFLUENCE_PERSONAL_TOKEN": "{env:CONFLUENCE_PERSONAL_TOKEN}"
			},
			"enabled": false
		},
		"bitbucket": {
			"type":"local",
			"command": ["/usr/local/bin/bbmcp"],
			"enabled": false
		}
	}
}
