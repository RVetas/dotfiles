{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"mail": {
			"type": "local",
			"command": [
				"mcp-email-server",
				"stdio"
			],
			"environment": {
				"REQUESTS_CA_BUNDLE": "/Users/rvetas/dotfiles/certs/davmail.pem",
				"SSL_CERT_FILE": "/Users/rvetas/dotfiles/certs/davmail.pem",
				"MCP_EMAIL_SERVER_ACCOUNT_NAME": "Work",
				"MCP_EMAIL_SERVER_FULL_NAME": "{env:ADNAME}",
				"MCP_EMAIL_SERVER_EMAIL_ADDRESS": "{env:ADMAIL}",
				"MCP_EMAIL_SERVER_USER_NAME": "{env:FULL_ADLOGIN}",
				"MCP_EMAIL_SERVER_PASSWORD": "{env:ADPASS}",
				"MCP_EMAIL_SERVER_IMAP_HOST": "localhost",
				"MCP_EMAIL_SERVER_IMAP_PORT": "1143",
				"MCP_EMAIL_SERVER_IMAP_SSL": "true",
				"MCP_EMAIL_SERVER_SMTP_HOST": "localhost",
				"MCP_EMAIL_SERVER_SMTP_PORT": "1145",
				"MCP_EMAIL_SERVER_SMTP_SSL": "true"
			},
			"enabled": false
		},
		"atlassian": {
			"type": "local",
			"command": [
				"uvx",
				"--python=3.12",
				"mcp-atlassian",
				"--no-jira-ssl-verify",
				"--no-confluence-ssl-verify"
			],
			"environment": {
				"JIRA_URL": "{env:JIRA_URL}",
				"JIRA_PERSONAL_TOKEN": "{env:JIRA_PERSONAL_TOKEN}",
				"CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
				"CONFLUENCE_PERSONAL_TOKEN": "{env:CONFLUENCE_PERSONAL_TOKEN}"
			},
			"enabled": false
		},
		"figma": {
			"type": "remote",
			"url": "http://127.0.0.1:3845/mcp",
			"enabled": false
		},
		"alfaui": {
			"type": "remote",
			"url": "http://127.0.0.1:2201/mcp",
			"oauth": false,
			"enabled": false
		},
		"bitbucket": {
			"type":"local",
			"command": ["/usr/local/bin/bbmcp"],
			"enabled": false
		},
		"testops": {
			"type": "remote",
			"url": "{env:TESTOPS_URL}",
			"oauth": false,
			"enabled": false,
			"headers": {
				"X-TestOps-Token": "{env:TESTOPS_TOKEN}"
			}
		},
		"xcodebuildmcp": {
			"type": "local",
			"command": ["npx", "-y", "xcodebuildmcp@latest", "mcp"],
			"enabled": false
		},
		"xcode": {
			"type": "local",
			"command": ["xcrun", "mcpbridge"],
			"enabled": false
		},
		"camunda": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"mcp/camunda",
				"-e",
				"CAMUNDA_HOST={env:CAMUNDA_HOST}"
			],
			"enabled": false
		}
	}
}
